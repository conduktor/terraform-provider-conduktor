{
  "apiVersion": "v1",
  "kind": "ServiceAccount",
  "metadata": {
    "name": "sa-schema-registry",
    "cluster": "my-kafka-cluster"
  },
  "spec": {
    "authorization": {
      "acls": [
        {
          "type": "TOPIC",
          "name": "my-topic",
          "patternType": "LITERAL",
          "operations": [
            "Read"
          ]
        }
      ],
      "type": "KAFKA_ACL"
    },
    "schemaRegistryAuthorization": {
      "acls": [
        {
          "name": "my-subject",
          "patternType": "LITERAL",
          "operations": [
            "Read",
            "Write"
          ]
        }
      ]
    }
  }
}
